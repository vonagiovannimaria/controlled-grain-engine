                    "text": "in 1"
                }
            },
            {
                "box": {
                    "code": "// Grain envelope selector\r\n//\r\n// in1 = x, fase del grano 0. -> 1.\r\n// in2 = shape:\r\n//       0 = Hann\r\n//       1 = Triangolare\r\n//       2 = Gaussiano\r\n//       3 = Trapezoidale\r\n//       4 = Tukey\r\n//       5 = Blackman\r\n//       6 = Percussivo\r\n//\r\n// in3 = paramA\r\n//      Gaussiano: sigma\r\n//      Trapezoidale: attack\r\n//      Tukey: edge\r\n//      Percussivo: attack\r\n//\r\n// in4 = paramB\r\n//      Gaussiano: mu\r\n//      Trapezoidale: release\r\n//      Percussivo: decay_curve\r\n\r\nx = clamp(in1, 0, 1);\r\nshape = floor(in2 + 0.5);\r\n\r\nparamA = in3;\r\nparamB = in4;\r\n\r\ny = 0;\r\n\r\n// 0. Hann\r\nif (shape == 0) {\r\n    y = 0.5 - 0.5 * cos(2 * pi * x);\r\n}\r\n\r\n// 1. Triangolare\r\nelse if (shape == 1) {\r\n    y = 1 - abs((2 * x) - 1);\r\n}\r\n\r\n// 2. Gaussiano normalizzato\r\nelse if (shape == 2) {\r\n    sigma = max(paramA, 0.0001);\r\n    mu = paramB;\r\n    num = pow(x - mu, 2);\r\n    den = 2 * pow(sigma, 2);\r\n    y = exp(-num / den);\r\n}\r\n\r\n// 3. Trapezoidale\r\nelse if (shape == 3) {\r\n    attack = clamp(paramA, 0.0001, 0.4999);\r\n    release = clamp(paramB, 0.0001, 0.4999);\r\n\r\n    if (x < attack) {\r\n        y = x / attack;\r\n    }\r\n    else if (x > 1 - release) {\r\n        y = (1 - x) / release;\r\n    }\r\n    else {\r\n        y = 1;\r\n    }\r\n}\r\n\r\n// 4. Tukey semplificato (tapered cosine)\r\nelse if (shape == 4) {\r\n    edge = clamp(paramA, 0.0001, 0.4999);\r\n\r\n    if (x < edge) {\r\n        phase = x / edge;\r\n        y = 0.5 - 0.5 * cos(pi * phase);\r\n    }\r\n    else if (x > 1 - edge) {\r\n        phase = (1 - x) / edge;\r\n        y = 0.5 - 0.5 * cos(pi * phase);\r\n    }\r\n    else {\r\n        y = 1;\r\n    }\r\n}\r\n\r\n// 5. Blackman\r\nelse if (shape == 5) {\r\n    y = 0.42 - 0.5 * cos(2 * pi * x) + 0.08 * cos(4 * pi * x);\r\n}\r\n\r\n// 6. Percussivo\r\nelse if (shape == 6) {\r\n    attack = clamp(paramA, 0.0001, 0.9999);\r\n    decay_curve = max(paramB, 0.0001);\r\n\r\n    if (x < attack) {\r\n        y = x / attack;\r\n    }\r\n    else {\r\n        phase = (1 - x) / (1 - attack);\r\n        y = pow(phase, decay_curve);\r\n    }\r\n}\r\n\r\n// fallback: Hann\r\nelse {\r\n    y = 0.5 - 0.5 * cos(2 * pi * x);\r\n}\r\n\r\nout1 = clamp(y, 0, 1);",
                    "fontface": 0,
                    "fontname": "<Monospaced>",
                    "fontsize": 12.0,
                    "id": "obj-5",
                    "maxclass": "codebox",
                    "numinlets": 4,
                    "numoutlets": 1,
                    "outlettype": [ "" ],
                    "patching_rect": [ 29.0, 137.0, 512.0, 606.0 ]
                }
            }
